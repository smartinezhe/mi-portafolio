---
const {class: className = '', ...props} = Astro.props;
---

<a
	class={`text-gray-200
    border border-white/10 rounded-full
    flex justify-center items-center gap-x-2
    py-1 px-2 lg:py-2 lg:px-4
    transition
    hover:scale-105
    ${className}
    `}
	target="_blank"
	rel="noopener noreferrer"
	role="link"
	{...props}>
	<slot />
</a>
