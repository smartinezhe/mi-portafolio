---
import Logo from '../assets/logo/Logo.astro';
import LinkedInIcon from '../assets/icons/LinkedIn.astro';
import EmailIcon from '../assets/icons/Email.astro';
import GitHubIcon from '../assets/icons/GitHub.astro';
import SocialPill from '../assets/icons/SocialPill.astro';

const profile = 'Salem Martínez | Ingeniero de Sistemas y Desarrollador Web';
---

<div class="flex items-center gap-x-2 mb-2">
	<Logo class="size-20 mb-4" aria-label={profile} role="img" />
	<h1
		class="text-white text-3xl md:text-4xl lg:text-5xl font-bold flex gap-x-4 pb-4">
		Salem Martínez
	</h1>
</div>
<h2 class="text-gray-200 text-xl lg:text-2xl text-wrap max-w-175 opacity-80">
	Desarrollo aplicaciones web que optimizan los procesos operativos de las
	pymes.
</h2>
<nav class="flex gap-4 mt-8 flex-wrap">
	<SocialPill
		href="mailto:smartinezhe1@gmail.com"
		class="bg-green-600 border border-green-700 hover:bg-green-700 text-white shadow-sm shadow-black/30 focus-visible:ring-green-500/50 min-w-35 justify-center">
		<EmailIcon class="size-5" /> Contáctame
	</SocialPill>
	<SocialPill
		href="https://www.linkedin.com/in/salem-martinez-h/"
		class="bg-blue-600 border border-blue-700 hover:bg-blue-700 text-white shadow-sm shadow-black/30 focus-visible:ring-blue-500/50 min-w-35 justify-center">
		<LinkedInIcon class="size-5" /> LinkedIn
	</SocialPill>
	<SocialPill
		href="https://github.com/smartinezhe"
		class="bg-purple-600 border border-purple-700 hover:bg-purple-700 text-white shadow-sm shadow-black/30 focus-visible:ring-purple-500/50 min-w-35 justify-center">
		<GitHubIcon class="size-5" /> GitHub
	</SocialPill>
</nav>
