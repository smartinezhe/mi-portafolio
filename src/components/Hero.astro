---
import Logo from '../assets/logo/Logo.astro';
import WhatsAppIcon from '../assets/icons/WhatsApp.astro';
import GitHubIcon from '../assets/icons/GitHub.astro';
import ContactButton from '../assets/icons/ContactButton.astro';

const profile = 'Salem Martínez | Desarrollador Full Stack PHP/Laravel';

const whatsappNumber = '573125815262';

const whatsappMessage = encodeURIComponent(
	'Hola Salem, vi tu portafolio y me gustaría conversar contigo.'
);

const whatsappUrl = `https://wa.me/${whatsappNumber}?text=${whatsappMessage}`;
---

<div class="flex flex-col gap-6">
	<div class="flex flex-col gap-4">
		<Logo class="size-40" aria-label={profile} role="img" />

		<h1 class="text-white text-3xl md:text-4xl lg:text-5xl font-bold">
			Salem Martínez
		</h1>
	</div>

	<h2 class="text-gray-200 text-xl lg:text-2xl text-wrap max-w-175 opacity-80">
		Construyo aplicaciones web modernas y escalables con PHP y Laravel.
	</h2>

	<nav class="flex gap-4 flex-wrap">
		<ContactButton
			href={whatsappUrl}
			class="bg-green-400 border border-green-500 hover:bg-green-500 text-black font-semibold shadow-sm shadow-black/30 focus-visible:ring-green-500/50 min-w-35 justify-center">
			<WhatsAppIcon class="size-5" /> Contáctame
		</ContactButton>

		<ContactButton
			href="https://github.com/smartinezhe"
			class="bg-slate-300 border border-slate-400 hover:bg-slate-400 text-black font-semibold shadow-sm shadow-black/30 focus-visible:ring-slate-500/50 min-w-35 justify-center">
			<GitHubIcon class="size-5" /> GitHub
		</ContactButton>
	</nav>
</div>
