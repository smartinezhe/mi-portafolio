---
const startYear = 2026;
const currentYear = new Date().getFullYear();
const displayYear =
	startYear === currentYear ? currentYear : `${startYear}–${currentYear}`;
---

<footer class="mx-auto mt-16 w-full max-w-5xl px-4 pb-6">
	<div
		class="flex justify-center rounded-lg border border-white/10 bg-white/3 py-4">
		<span class="text-center text-sm text-gray-200 opacity-80">
			© {displayYear}
			<a
				href="https://smartinezhe.netlify.app"
				class="hover:underline"
				rel="noopener noreferrer">
				Salem Martínez</a
			>.Todos los derechos reservados.
		</span>
	</div>
</footer>
