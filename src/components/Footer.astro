---
const startYear = 2026;
const currentYear = new Date().getFullYear();
const displayYear =
	startYear === currentYear ? currentYear : `${startYear}–${currentYear}`;
---

<footer class="m-4 mt-16 w-full mx-auto container flex justify-center">
	<div
		class="rounded-lg w-full max-w-7xl mx-auto flex items-center justify-center py-4">
		<span class="text-gray-200 text-sm text-center opacity-80">
			© {displayYear}
			<a href="https://smartinezhe1.pages.dev" class="hover:underline"
				>Salem Martínez</a
			>. Todos los derechos reservados.
		</span>
	</div>
</footer>
