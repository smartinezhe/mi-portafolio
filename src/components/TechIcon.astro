---
const {icon: Icon, name, color} = Astro.props;
---

<div
	class="relative flex flex-col items-center justify-center gap-3
  w-full max-w-42.5 aspect-17/14 rounded-2xl
  bg-white/5 backdrop-blur-md border border-white/10
  hover:bg-white/10 hover:border-white/20
  transition-all duration-300 group cursor-pointer">
	<div
		class="absolute inset-0 rounded-2xl opacity-0 group-hover:opacity-100 transition duration-300 bg-linear-to-br from-white/10 to-transparent blur-xl">
	</div>

	<Icon
		style={`color: ${color}`}
		class="size-20 z-10 transition-all duration-300
    group-hover:scale-110 group-hover:-translate-y-1"
	/>

	<span
		class="text-xs text-gray-300 opacity-80 z-10
    group-hover:text-white transition">
		{name}
	</span>
</div>
